#!/usr/bin/env bash
set -euo pipefail

title=$(git log -1 --pretty=%s)
body=$(git log -1 --pretty=%b)

git push -f
if gh pr view &>/dev/null; then
  gh pr edit --title "$title" --body "$body"
else
  gh pr create --fill "$@"
fi

url=$(gh pr view --json url -q .url)
printf '%s' "$url" | wl-copy >/dev/null 2>&1
echo "Copied to clipboard: $url"

