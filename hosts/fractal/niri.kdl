output "HDMI-A-1" {
    position x=0 y=0
    scale 1.3
    transform "90"
}
output "DP-1" {
    mode "3840x2160@138.0"
}
output "DP-2" {
    off
    mode "3840x2160@60.0"
    scale 2.0
}
spawn-at-startup "firefox"
spawn-at-startup "discord"
spawn-at-startup "steam"
workspace "steam" {
    open-on-output "DP-1"
}
workspace "main" {
    open-on-output "DP-1"
}
workspace "chat" {
    open-on-output "HDMI-A-1"
}
window-rule {
    // Float gam
    match title="client"
    open-floating true
}
